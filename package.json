{
  "name": "batch-encoder",
  "version": "1.3.1",
  "author": "AnimeThemes",
  "repo": "animethemes-batch-encoder-ts",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "eslint": "eslint .",
    "lint": "eslint . --fix && prettier src",
    "start": "bun run src/index.ts",
    "build:win": "bun build src/index.ts --compile --target=bun-windows-x64 --minify --outfile dist/batch-encoder.exe"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.6.0",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.0",
    "string-argv": "^0.3.2",
    "valibot": "^1.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/cli-progress": "^3.11.6",
    "eslint": "^10.4.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.60.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
